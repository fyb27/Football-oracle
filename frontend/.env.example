# Frontend build/runtime configuration.

# Base public path. "/football-oracle/" for GitHub Pages project sites,
# "/" for a custom domain or local preview.
VITE_BASE=/football-oracle/

# API base URL the built app calls. Leave blank in dev (Vite proxies /api to
# the backend). In production set to your deployed backend, e.g.
# https://football-oracle-api.onrender.com
VITE_API_URL=

# Dev-only: where Vite proxies /api during `npm run dev`.
VITE_DEV_API=http://localhost:4000
